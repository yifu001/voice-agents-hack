# macOS
.DS_Store

# Xcode — user-specific state
xcuserdata/
*.xcuserstate
*.xcuserdatad/

# Xcode — build artifacts
build/
DerivedData/
*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/

# Swift Package Manager
.build/
.swiftpm/
Packages/
Package.resolved

# MeshNode app (AryaaBluetoothMesh): all local model weights and tokenizer assets.
# Huge; never commit. Populate locally (see AryaaBluetoothMesh/ios/SETUP.md).
AryaaBluetoothMesh/ios/MeshNode/Models/
AryaaBluetoothMesh/ios/MeshNode/Models/**

# Vendored binary frameworks — rebuild with `cactus build --apple`.
# See AryaaBluetoothMesh/ios/SETUP.md.
AryaaBluetoothMesh/ios/Vendor/

# Parakeet model weights for TacNet (bundled in app, too large for git)
TacNet/Resources/ParakeetCTC/*
!TacNet/Resources/ParakeetCTC/.gitkeep

# Python venvs / caches
venv/
.venv/
__pycache__/
*.pyc
*.mp4
